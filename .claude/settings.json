{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -q 'git commit'; then \"$CLAUDE_PROJECT_DIR\"/test/lint.sh; fi",
            "timeout": 120,
            "statusMessage": "Running lint checks..."
          }
        ]
      }
    ]
  }
}
